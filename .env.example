APP_NAME=Prompt Optimization Studio
APP_ENV=development
API_V1_PREFIX=/api/v1
DATA_DIR=data
DATABASE_URL=sqlite:///data/app.db
OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:18080/v1
OPENAI_DEFAULT_MODEL=deepseek-v4-pro
MAX_UPLOAD_SIZE_MB=25
MAX_ARTIFACT_SIZE_MB=250
MAX_GENERATED_EXAMPLES=500
MAX_EXAMPLES_PER_RUN=1000
MAX_OPTIMIZER_THREADS=4
MAX_LM_CALLS=5000
MAX_METRIC_CALLS=5000
MAX_RUNTIME_SECONDS=7200
